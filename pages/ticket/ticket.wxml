<view class="ticket-page">
  <button class="close" bindtap="closeTicket">Close</button>

  <view class="pass-card">
    <view class="pass-title">{{title}}</view>

    <view class="qr-wrap">
      <image class="qr-image" src="{{qrSrc}}" mode="aspectFit"></image>
    </view>

    <text wx:if="{{isSingle}}" class="transfer">Request transfer from driver</text>

    <view class="brand-ticket">
      <view class="color-strip">
        <view style="background-color: {{colors[0]}}"></view>
        <view style="background-color: {{colors[1]}}"></view>
        <view style="background-color: {{colors[2]}}"></view>
        <text class="live-time" style="left: {{timeLeft}}%">{{ticketTime}}</text>
      </view>

      <view class="brand-area">
        <view class="ride-mark">
          <view class="mark-ring"></view>
          <view class="mark-wing"></view>
          <view class="mark-cut"></view>
        </view>
        <text class="brand-text">TheRide</text>
      </view>

      <view wx:if="{{isDay}}" class="activated">Activated {{activatedClock}}</view>
    </view>

    <view class="spacer"></view>

    <view class="card-footer">
      <button>••• Actions</button>
      <button>☷ Details</button>
    </view>
  </view>
</view>

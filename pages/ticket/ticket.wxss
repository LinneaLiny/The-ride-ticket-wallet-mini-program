.ticket-page {
  min-height: 100vh;
  background: #f7f7f7;
  box-sizing: border-box;
}

.close {
  display: block;
  width: 150rpx;
  margin: 82rpx auto 30rpx 36rpx;
  color: #2a2a2a;
  font-size: 38rpx;
  font-weight: 500;
  text-align: left;
}

.pass-card {
  width: calc(100vw - 56rpx);
  min-height: auto;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  background: #fff;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 12rpx 24rpx rgba(0, 0, 0, 0.16);
}

.pass-title {
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  padding-left: 54rpx;
  box-sizing: border-box;
  background: #2d2d2d;
  color: #fff;
  font-size: 36rpx;
  font-weight: 500;
  letter-spacing: 1.5rpx;
}

.qr-wrap {
  padding: 40rpx 0 30rpx;
  display: flex;
  justify-content: center;
}

.qr-image {
  width: 62vw;
  height: 62vw;
  max-width: 540rpx;
  max-height: 540rpx;
  display: block;
}

.transfer {
  margin: 0 0 24rpx;
  color: #777;
  font-size: 34rpx;
  font-weight: 400;
  letter-spacing: 4rpx;
  text-align: center;
}

.brand-ticket {
  width: calc(100% - 72rpx);
  margin: 0 auto;
  border-radius: 12rpx;
  overflow: hidden;
}

.color-strip {
  position: relative;
  height: 118rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
}

.color-strip view {
  min-width: 0;
}

.live-time {
  position: absolute;
  top: 27rpx;
  transform: translateX(-50%);
  color: #fff;
  font-family: "Helvetica Neue", Arial, sans-serif;
  font-size: 48rpx;
  font-weight: 700;
  text-shadow: 0 4rpx 8rpx #000, 0 0 8rpx #000;
  white-space: nowrap;
}

.brand-area {
  height: 346rpx;
  padding: 0 30rpx;
  display: flex;
  align-items: center;
  background: #eceff3;
  box-sizing: border-box;
}

.ride-mark {
  position: relative;
  width: 188rpx;
  height: 188rpx;
  margin-right: 22rpx;
  flex: 0 0 auto;
}

.mark-ring {
  position: absolute;
  inset: 10rpx;
  border: 16rpx solid #ff3842;
  border-radius: 50%;
}

.mark-wing {
  position: absolute;
  left: 4rpx;
  top: 66rpx;
  width: 130rpx;
  height: 60rpx;
  background: #ff3842;
  transform: skewX(-24deg);
  border-radius: 2rpx;
}

.mark-cut {
  position: absolute;
  left: 122rpx;
  top: 58rpx;
  width: 30rpx;
  height: 76rpx;
  background: #004789;
  transform: skewX(-20deg);
  border-left: 14rpx solid #eceff3;
}

.brand-text {
  color: #004789;
  font-family: "Helvetica Neue", Arial, sans-serif;
  font-size: 92rpx;
  font-weight: 800;
  white-space: nowrap;
  line-height: 1;
}

.activated {
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #d00707;
  color: #fff;
  font-size: 34rpx;
  font-weight: 800;
  letter-spacing: 3rpx;
}

.spacer {
  height: 150rpx;
  border-bottom: 4rpx dotted #2a2a2a;
}

.card-footer {
  height: 116rpx;
  padding: 0 36rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.card-footer button {
  color: #078aad;
  font-size: 38rpx;
  font-weight: 400;
}

@media (max-width: 360px) {
  .pass-title {
    font-size: 30rpx;
  }

  .qr-image {
    width: 66vw;
    height: 66vw;
  }

  .brand-ticket {
    width: calc(100% - 58rpx);
  }

  .brand-area {
    padding: 0 24rpx;
  }

  .ride-mark {
    width: 166rpx;
    height: 166rpx;
    margin-right: 18rpx;
  }

  .mark-wing {
    top: 58rpx;
    width: 116rpx;
    height: 54rpx;
  }

  .mark-cut {
    left: 108rpx;
    top: 52rpx;
    height: 68rpx;
  }

  .brand-text {
    font-size: 78rpx;
  }

  .live-time {
    font-size: 42rpx;
  }
}

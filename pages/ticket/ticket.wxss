.ticket-page {
  min-height: 100vh;
  background: #f7f7f7;
}

.phone-bar {
  height: 104rpx;
  padding: 32rpx 78rpx 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
}

.plain-time {
  color: #000;
  font-size: 34rpx;
  font-weight: 600;
}

.status-right {
  display: flex;
  align-items: center;
  gap: 10rpx;
  color: #111;
  font-size: 28rpx;
  font-weight: 700;
}

.signal {
  display: flex;
  align-items: flex-end;
  gap: 4rpx;
  height: 30rpx;
}

.signal view {
  width: 8rpx;
  background: #111;
  border-radius: 4rpx;
}

.signal view:nth-child(1) { height: 10rpx; }
.signal view:nth-child(2) { height: 16rpx; }
.signal view:nth-child(3) { height: 22rpx; }
.signal view:nth-child(4) { height: 28rpx; }

.battery {
  padding: 2rpx 10rpx;
  border-radius: 10rpx;
  background: #111;
  color: #fff;
  font-size: 24rpx;
}

.close {
  display: block;
  margin: 30rpx 68rpx 30rpx auto;
  color: #2a2a2a;
  font-size: 38rpx;
}

.pass-card {
  width: calc(100vw - 72rpx);
  min-height: calc(100vh - 210rpx);
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  background: #fff;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 12rpx 24rpx rgba(0, 0, 0, 0.16);
}

.pass-title {
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #2d2d2d;
  color: #fff;
  font-size: 34rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
}

.qr-wrap {
  padding: 42rpx 0 24rpx;
  display: flex;
  justify-content: center;
}

.qr {
  position: relative;
  width: 516rpx;
  height: 516rpx;
  background: #fff;
}

.qr-row {
  display: flex;
  height: 17.793rpx;
}

.qr-cell {
  width: 17.793rpx;
  height: 17.793rpx;
}

.qr-cell.dark {
  background: #000;
}

.qr-center {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 130rpx;
  height: 130rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  transform: translate(-50%, -50%);
}

.qr-center > view {
  width: 100rpx;
  height: 100rpx;
  border: 12rpx solid #000;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.qr-center > view > view {
  width: 58rpx;
  height: 58rpx;
  border: 10rpx solid #000;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.qr-center > view > view > view {
  width: 16rpx;
  height: 16rpx;
  background: #000;
}

.transfer {
  margin: 4rpx 0 24rpx;
  color: #777;
  font-size: 36rpx;
  font-weight: 800;
  letter-spacing: 4rpx;
  text-align: center;
}

.brand-ticket {
  width: calc(100% - 78rpx);
  margin: 0 auto;
  border-radius: 12rpx;
  overflow: hidden;
}

.color-strip {
  position: relative;
  height: 122rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
}

.color-strip view {
  min-width: 0;
}

.live-time {
  position: absolute;
  top: 30rpx;
  transform: translateX(-50%);
  color: #fff;
  font-size: 42rpx;
  font-weight: 800;
  text-shadow: 0 3rpx 8rpx #000, 0 0 8rpx #000;
  white-space: nowrap;
}

.brand-area {
  height: 360rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  background: #eceff3;
  box-sizing: border-box;
}

.ride-mark {
  position: relative;
  width: 158rpx;
  height: 158rpx;
  margin-right: 18rpx;
  flex: 0 0 auto;
}

.mark-circle {
  position: absolute;
  inset: 10rpx;
  border: 15rpx solid #fb3740;
  border-radius: 50%;
}

.mark-slash {
  position: absolute;
  left: 18rpx;
  top: 54rpx;
  width: 124rpx;
  height: 50rpx;
  background: #fb3740;
  transform: skewX(-24deg);
  box-shadow: 58rpx 0 0 -28rpx #004789;
}

.brand-text {
  color: #004789;
  font-size: 76rpx;
  font-weight: 800;
  white-space: nowrap;
}

.activated {
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #d00707;
  color: #fff;
  font-size: 34rpx;
  font-weight: 800;
  letter-spacing: 3rpx;
}

.spacer {
  flex: 1;
  border-bottom: 4rpx dotted #2a2a2a;
}

.card-footer {
  height: 116rpx;
  padding: 0 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.card-footer button {
  color: #078aad;
  font-size: 36rpx;
  font-weight: 600;
}

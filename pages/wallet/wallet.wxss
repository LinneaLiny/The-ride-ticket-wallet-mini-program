.wallet-page {
  min-height: 100vh;
  padding-bottom: 52rpx;
  background: #f8f8f8;
  box-sizing: border-box;
}

.nav {
  margin-top: 74rpx;
  height: 128rpx;
  padding: 0 38rpx;
  display: grid;
  grid-template-columns: 180rpx 1fr 92rpx;
  align-items: center;
}

.back {
  display: flex;
  align-items: center;
  justify-self: start;
  color: #2b2b2b;
  font-size: 38rpx;
  font-weight: 500;
}

.chevron {
  margin-right: 6rpx;
  font-size: 86rpx;
  line-height: 36rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 800;
  text-align: center;
  white-space: nowrap;
}

.refresh {
  justify-self: end;
  color: #2b2b2b;
  font-size: 58rpx;
  line-height: 1;
}

.tabs {
  display: grid;
  grid-template-columns: 1fr 1fr;
  height: 122rpx;
  margin-bottom: 38rpx;
}

.tab {
  font-size: 40rpx;
  font-weight: 800;
}

.tab.active {
  background: #fff;
  color: #111;
}

.tab.muted {
  background: #939393;
  color: #fff;
}

.ticket-list {
  padding: 0 36rpx;
  box-sizing: border-box;
}

.wallet-card {
  display: block;
  width: 100%;
  margin: 0 auto 40rpx;
  padding: 48rpx 50rpx 42rpx;
  box-sizing: border-box;
  background: #fff;
  box-shadow: 0 18rpx 28rpx rgba(0, 0, 0, 0.24);
  text-align: left;
}

.card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 44rpx;
  gap: 20rpx;
}

.card-title {
  color: #111;
  font-size: 38rpx;
  font-weight: 800;
  line-height: 1.08;
  white-space: normal;
}

.active-text {
  color: #138d12;
  font-size: 36rpx;
  font-weight: 800;
  white-space: nowrap;
}

.brand-panel {
  height: 356rpx;
  padding: 0 34rpx;
  display: flex;
  align-items: center;
  background: #eceff3;
  overflow: hidden;
}

.ride-mark {
  position: relative;
  width: 198rpx;
  height: 198rpx;
  margin-right: 22rpx;
  flex: 0 0 auto;
}

.mark-ring {
  position: absolute;
  inset: 10rpx;
  border: 16rpx solid #ff3842;
  border-radius: 50%;
}

.mark-wing {
  position: absolute;
  left: 4rpx;
  top: 70rpx;
  width: 136rpx;
  height: 62rpx;
  background: #ff3842;
  transform: skewX(-24deg);
  border-radius: 2rpx;
}

.mark-cut {
  position: absolute;
  left: 128rpx;
  top: 62rpx;
  width: 32rpx;
  height: 78rpx;
  background: #004789;
  transform: skewX(-20deg);
  border-left: 14rpx solid #eceff3;
}

.brand-text {
  color: #004789;
  font-size: 96rpx;
  font-weight: 800;
  white-space: nowrap;
  line-height: 1;
}

.expires {
  display: block;
  margin-top: 32rpx;
  color: #787878;
  font-size: 30rpx;
  line-height: 1.25;
}

@media (max-width: 360px) {
  .nav {
    grid-template-columns: 160rpx 1fr 76rpx;
  }

  .back,
  .tab {
    font-size: 34rpx;
  }

  .title {
    font-size: 36rpx;
  }

  .wallet-card {
    padding-left: 40rpx;
    padding-right: 40rpx;
  }

  .ride-mark {
    width: 174rpx;
    height: 174rpx;
    margin-right: 18rpx;
  }

  .mark-wing {
    top: 60rpx;
    width: 120rpx;
    height: 56rpx;
  }

  .mark-cut {
    left: 112rpx;
    top: 54rpx;
    height: 70rpx;
  }

  .brand-text {
    font-size: 82rpx;
  }
}

.wallet-actions {
  padding: 18rpx 44rpx 0;
}

.buy-button {
  width: 100%;
  height: 120rpx;
  border-radius: 16rpx;
  background: #2d2d2d;
  color: #fff;
  font-size: 38rpx;
  font-weight: 800;
  box-shadow: 0 14rpx 24rpx rgba(0, 0, 0, 0.25);
}

.account-button {
  width: 100%;
  margin-top: 76rpx;
  color: #111;
  font-size: 38rpx;
  font-weight: 800;
}

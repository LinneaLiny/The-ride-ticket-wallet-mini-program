.wallet-page {
  min-height: 100vh;
  padding-bottom: 54rpx;
  background: #f8f8f8;
}

.phone-bar {
  height: 104rpx;
  padding: 26rpx 64rpx 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
}

.status-time {
  min-width: 136rpx;
  padding: 8rpx 20rpx;
  border-radius: 28rpx;
  background: #2dbb55;
  color: #fff;
  font-size: 34rpx;
  line-height: 1;
}

.status-right {
  display: flex;
  align-items: center;
  gap: 10rpx;
  color: #111;
  font-size: 28rpx;
  font-weight: 600;
}

.signal {
  display: flex;
  align-items: flex-end;
  gap: 4rpx;
  height: 30rpx;
}

.signal view {
  width: 8rpx;
  background: #111;
  border-radius: 4rpx;
}

.signal view:nth-child(1) { height: 10rpx; }
.signal view:nth-child(2) { height: 16rpx; }
.signal view:nth-child(3) { height: 22rpx; }
.signal view:nth-child(4) { height: 28rpx; }

.battery {
  padding: 2rpx 10rpx;
  border-radius: 10rpx;
  background: #111;
  color: #fff;
  font-size: 24rpx;
}

.nav {
  height: 116rpx;
  padding: 0 38rpx;
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  align-items: center;
}

.back {
  display: flex;
  align-items: center;
  justify-self: start;
  color: #2b2b2b;
  font-size: 40rpx;
}

.chevron {
  margin-right: 6rpx;
  font-size: 86rpx;
  line-height: 36rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 800;
}

.refresh {
  justify-self: end;
  color: #2b2b2b;
  font-size: 58rpx;
  line-height: 1;
}

.tabs {
  display: grid;
  grid-template-columns: 1fr 1fr;
  height: 122rpx;
  margin-bottom: 36rpx;
}

.tab {
  font-size: 40rpx;
  font-weight: 800;
}

.tab.active {
  background: #fff;
  color: #111;
}

.tab.muted {
  background: #939393;
  color: #fff;
}

.ticket-list {
  padding: 0 38rpx;
}

.wallet-card {
  display: block;
  width: 100%;
  margin-bottom: 40rpx;
  padding: 52rpx 50rpx 42rpx;
  box-sizing: border-box;
  background: #fff;
  box-shadow: 0 18rpx 28rpx rgba(0, 0, 0, 0.24);
  text-align: left;
}

.card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 46rpx;
}

.card-title {
  color: #111;
  font-size: 38rpx;
  font-weight: 800;
}

.active-text {
  color: #138d12;
  font-size: 36rpx;
  font-weight: 800;
}

.brand-panel {
  height: 356rpx;
  padding: 0 28rpx;
  display: flex;
  align-items: center;
  background: #eceff3;
  overflow: hidden;
}

.ride-mark {
  position: relative;
  width: 158rpx;
  height: 158rpx;
  margin-right: 18rpx;
  flex: 0 0 auto;
}

.mark-circle {
  position: absolute;
  inset: 10rpx;
  border: 16rpx solid #fb3740;
  border-radius: 50%;
}

.mark-slash {
  position: absolute;
  left: 18rpx;
  top: 54rpx;
  width: 124rpx;
  height: 50rpx;
  background: #fb3740;
  transform: skewX(-24deg);
  box-shadow: 58rpx 0 0 -28rpx #004789;
}

.brand-text {
  color: #004789;
  font-size: 74rpx;
  font-weight: 800;
  white-space: nowrap;
}

.expires {
  display: block;
  margin-top: 32rpx;
  color: #787878;
  font-size: 30rpx;
}

.wallet-actions {
  padding: 18rpx 44rpx 0;
}

.buy-button {
  width: 100%;
  height: 120rpx;
  border-radius: 16rpx;
  background: #2d2d2d;
  color: #fff;
  font-size: 38rpx;
  font-weight: 800;
  box-shadow: 0 14rpx 24rpx rgba(0, 0, 0, 0.25);
}

.account-button {
  width: 100%;
  margin-top: 76rpx;
  color: #111;
  font-size: 38rpx;
  font-weight: 800;
}
